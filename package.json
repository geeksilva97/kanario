{
  "name": "kanario",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --env-file=.env --experimental-strip-types src/index.ts",
    "test": "CREDENTIAL_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa node --experimental-strip-types --experimental-sqlite --test 'src/**/*.test.ts'",
    "test:coverage": "CREDENTIAL_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa node --experimental-strip-types --experimental-sqlite --test --experimental-test-coverage 'src/**/*.test.ts'",
    "test:integration": "node --env-file=.env.test --experimental-strip-types --test test/wordpress.integration.test.ts",
    "server": "node --env-file=.env --experimental-strip-types --experimental-sqlite src/discord/server.ts",
    "discord:register": "node --env-file=.env --experimental-strip-types --experimental-sqlite src/discord/register.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.42.0",
    "fastify": "^5.7.4",
    "sharp": "^0.34.5"
  }
}
