# Copy this file to .env and fill in your credentials.
# Required for CLI: WP_URL, WP_USERNAME, WP_APP_PASSWORD, GEMINI_API_KEY, RUNPOD_API_KEY
# Required for Discord bot: DISCORD_TOKEN, DISCORD_PUBLIC_KEY, DISCORD_APPLICATION_ID
# Optional: ANTHROPIC_API_KEY (only needed with --model claude or as Gemini fallback)
# Optional: CREDENTIAL_ENCRYPTION_KEY (Discord bot only — encrypts stored credentials)

WP_URL=https://your-wordpress-site.com
WP_USERNAME=
WP_APP_PASSWORD=
GEMINI_API_KEY=
RUNPOD_API_KEY=
ANTHROPIC_API_KEY=
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
CREDENTIAL_ENCRYPTION_KEY=
